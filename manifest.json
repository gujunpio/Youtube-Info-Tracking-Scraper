{
  "manifest_version": 3,
  "name": "YT Channel Scraper",
  "version": "1.2",
  "description": "Click the extension on any YouTube channel page to instantly scrape its popular videos.",
  "permissions": [
    "tabs",
    "scripting",
    "clipboardWrite",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YT Channel Scraper"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.js"],
      "matches": ["*://*.youtube.com/*"]
    }
  ]
}
